#!/bin/sh
set -eu

keychain_value() {
    security find-generic-password -a "$USER" -s "$1" -w 2>/dev/null || {
        echo "Missing Keychain item: $1" >&2
        exit 1
    }
}

export ANTHROPIC_BASE_URL="$(keychain_value LITELLM_BASE_URL)"
export ANTHROPIC_AUTH_TOKEN="$(keychain_value LITELLM_AUTH_TOKEN)"

exec claude "$@"
